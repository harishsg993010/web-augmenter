{
  "manifest_version": 3,
  "name": "Web Augmenter",
  "version": "0.1.0",
  "description": "Turn any website into a programmable surface using natural language.",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Web Augmenter"
  },
  "background": {
    "service_worker": "src/background/serviceWorker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "scripting",
    "userScripts",
    "activeTab",
    "tabs",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/shared/*"],
      "matches": ["<all_urls>"]
    }
  ]
}