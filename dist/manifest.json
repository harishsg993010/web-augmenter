{
  "manifest_version": 3,
  "name": "Web Augmenter",
  "version": "0.1.0",
  "description": "Turn any website into a programmable surface using natural language.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Web Augmenter"
  },
  "background": {
    "service_worker": "background/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "scripting",
    "userScripts",
    "activeTab",
    "tabs",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "shared/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}